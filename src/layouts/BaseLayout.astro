---
import '../styles/theme.css';
import { SEO } from 'astro-seo';
import { siteData } from '../config/seo';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  currentPage?: string;
}

const { title, description, image, noindex, currentPage = 'home' } = Astro.props;

const seoProps = {
  ...siteData.default,
  title,
  description: description || siteData.default.description,
  openGraph: {
    basic: {
      ...siteData.default.openGraph.basic,
      title,
      url: Astro.url.href,
      ...(image && { image })
    },
    optional: {
      ...siteData.default.openGraph.optional,
      description: description || siteData.default.openGraph.optional.description
    }
  }
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="canonical" href={Astro.url.href} />
  <SEO {...seoProps} />
  {noindex && <meta name="robots" content="noindex" />}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Zalando+Sans+Expanded:ital,wght@0,400;0,700;0,800;0,900;1,400&display=swap" rel="stylesheet">
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Rachelle Ymay Skilling",
      "jobTitle": "Contemporary Artist",
      "description": "Bold. Geometric. Autobiographical.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Calgary",
        "addressRegion": "Alberta",
        "addressCountry": "Canada"
      },
      "sameAs": [
        "https://www.instagram.com/rachelle_ymay_skilling/",
        "mailto:Rachelleskilling@gmail.com"
      ]
    })}
  </script>
</head>
<body>
  <Sidebar currentPage={currentPage} />
  
  <main class="main-content">
    <slot />
  </main>
</body>
</html>