---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const publications = await getCollection('publications');
const sortedPublications = publications.sort((a, b) => parseInt(b.data.year) - parseInt(a.data.year));

function resolveImagePath(path) {
  if (!path) return path;
  if (typeof path === 'object' && path !== null) {
    path = path.url || path.path || path.src || '';
  }
  if (typeof path !== 'string') return path;
  if (path.startsWith('/assets/')) {
    return '../../' + path;
  }
  return path;
}
---

<BaseLayout title="Publications & Media - Rachelle Ymay Skilling" description="Publications, interviews, and media appearances by Rachelle Ymay Skilling">
  <main>
    <section>
      <h3>Publications & Media</h3>
      <ul class="exhibition-list">
        {sortedPublications.map((publication) => (
          <li class="exhibition-item">
            {publication.data.image && (
              <div class="exhibition-image">
                <img src={resolveImagePath(publication.data.image)} alt={publication.data.title} />
              </div>
            )}
            <h4>{publication.data.title}</h4>
            <p class="exhibition-venue">
              {publication.data.publisher && <span class="venue">{publication.data.publisher}</span>}
              {publication.data.location && <span class="location">, {publication.data.location}</span>}
              {publication.data.year && <span class="year"> ({publication.data.year})</span>}
            </p>
            {publication.data.links && publication.data.links.length > 0 && (
              <ul class="publication-links">
                {publication.data.links.map((link) => (
                  <li><a href={link} target="_blank" rel="noopener">{link}</a></li>
                ))}
              </ul>
            )}
            {publication.data.description && (
              <p class="exhibition-description">{publication.data.description}</p>
            )}
          </li>
        ))}
      </ul>
    </section>
  </main>
</BaseLayout>