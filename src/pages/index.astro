---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { resolveImagePath } from '../lib/images';

const artist = await getCollection('artist');
const artistInfo = artist[0]?.data || {};

const heroImage = resolveImagePath(artistInfo.heroImagePath, '');
const bioText = artistInfo.bio || '';
---

<BaseLayout 
  title="Rachelle Ymay Skilling - Contemporary Artist" 
  description={artistInfo.tagline}
  currentPage="home"
>
  <section class="text-center bg-royal-cobalt relative overflow-visible text-white z-10">
    {heroImage && (
      <div class="w-full border-4 border-[#FF1493]">
        <img src={heroImage} alt="Rachelle Ymay Skilling in her studio" class="w-full h-full object-cover" />
      </div>
    )}
    
    <div class="relative z-10 max-w-[1000px] mx-auto bg-royal-cobalt/70 p-12">
      <h1 class="font-zalando font-bold text-4xl uppercase tracking-wider mb-6 text-white">Rachelle Ymay Skilling</h1>
      <p class="font-montserrat text-lg leading-relaxed mb-8 max-w-[800px]">{bioText}</p>
      
      <div class="flex gap-4 flex-wrap">
        <a href="/facilitation" class="btn btn-primary">View Workshops</a>
        <a href="/portfolio" class="btn btn-secondary">Browse Artwork</a>
      </div>
    </div>
  </section>
</BaseLayout>