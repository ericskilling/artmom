---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const about = await getCollection('artist');
const artistInfo = about[0]?.data || {};
---

<BaseLayout title="About - Rachelle Ymay Skilling" description={`About ${artistInfo.name} - ${artistInfo.tagline}`}>
  <main>
    <section class="profile">
      <h3>{artistInfo.name}</h3>
      <p class="tagline">{artistInfo.tagline}</p>
      <div class="bio">
        <p>{artistInfo.bio}</p>
      </div>
      <dl class="details">
        <dt>Location</dt>
        <dd>{artistInfo.location}</dd>
        {artistInfo.activeSince && (
          <>
            <dt>Making Art Since</dt>
            <dd>{artistInfo.activeSince}</dd>
          </>
        )}
      </dl>
    </section>
  </main>
</BaseLayout>