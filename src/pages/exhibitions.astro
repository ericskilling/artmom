---
import { getCollection } from 'astro:content';

const exhibitions = await getCollection('exhibitions');
const sortedExhibitions = exhibitions.sort((a, b) => 
  new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime()
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Exhibitions - Rachelle Ymay Skilling</title>
    <meta name="description" content="Exhibitions by Rachelle Ymay Skilling" />
  </head>
  <body>
    <header>
      <nav>
        <h1>Rachelle Ymay Skilling</h1>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/portfolio">Portfolio</a></li>
          <li><a href="/exhibitions">Exhibitions</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <h2>Exhibitions</h2>
      <p class="intro">Exhibition history from 2018 to present.</p>

      <div class="exhibition-list">
        {sortedExhibitions.map((exhibition) => (
          <article class="exhibition-card">
            <h3>{exhibition.data.title}</h3>
            <div class="exhibition-venue">
              <span class="venue">{exhibition.data.venue}</span>
              <span class="location">{exhibition.data.location}</span>
            </div>
            <p class="dates">
              {new Date(exhibition.data.startDate).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })} - 
              {new Date(exhibition.data.endDate).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
            </p>
            {exhibition.data.description && (
              <p class="description">{exhibition.data.description}</p>
            )}
          </article>
        ))}
      </div>
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} Rachelle Ymay Skilling. All rights reserved.</p>
    </footer>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    line-height: 1.6;
    color: #333;
    background: #fafafa;
  }

  header {
    padding: 2rem;
    background: #fff;
    border-bottom: 1px solid #eee;
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  nav h1 {
    font-size: 1.5rem;
    font-weight: 600;
  }

  nav ul {
    display: flex;
    list-style: none;
    gap: 2rem;
  }

  nav a {
    text-decoration: none;
    color: #333;
    font-weight: 500;
  }

  nav a:hover {
    color: #666;
  }

  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .intro {
    color: #666;
    margin-bottom: 3rem;
  }

  .exhibition-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .exhibition-card {
    background: #fff;
    padding: 2rem;
    border: 1px solid #eee;
    border-radius: 8px;
  }

  .exhibition-card h3 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .exhibition-venue {
    display: flex;
    gap: 0.5rem;
    color: #555;
    margin-bottom: 0.5rem;
  }

  .venue {
    font-weight: 500;
  }

  .dates {
    color: #666;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .description {
    color: #555;
    line-height: 1.6;
  }

  footer {
    text-align: center;
    padding: 2rem;
    background: #fff;
    border-top: 1px solid #eee;
    color: #666;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    nav {
      flex-direction: column;
      text-align: center;
    }
  }
</style>