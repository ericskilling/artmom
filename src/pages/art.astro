---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const artworks = await getCollection('artworks');
const sortedArtworks = artworks.sort((a, b) => parseInt(b.data.year) - parseInt(a.data.year));

function resolveImagePath(path) {
  if (!path || typeof path !== 'string') return path;
  if (path.startsWith('/assets/')) {
    return '../../' + path;
  }
  return path;
}
---

<BaseLayout title="Art - Rachelle Ymay Skilling" description="Contemporary artwork from Calgary artist Rachelle Ymay Skilling">
  <main>
    <section id="portfolio">
      <h3>Art</h3>
      <div class="artwork-grid">
        {sortedArtworks.map((artwork, index) => (
          <article class={`artwork-card artwork-card-${index + 1}`}>
            <div class="card-accent-top"></div>
            {artwork.data.artworkImage ? (
              <div class="artwork-image-wrap">
                <img src={resolveImagePath(artwork.data.artworkImage)} alt={artwork.data.title} />
              </div>
            ) : (
              <div class={`artwork-image-wrap artwork-placeholder artwork-placeholder-${(index % 3) + 1}`}>
                <div class="placeholder-pattern"></div>
              </div>
            )}
            <div class="card-content">
              <h4>{artwork.data.title}</h4>
              <p class="artwork-year">{artwork.data.year}</p>
              <p class="artwork-medium">{artwork.data.medium}</p>
              {artwork.data.dimensions && (
                <p class="artwork-dimensions">{artwork.data.dimensions}</p>
              )}
              {artwork.data.description && (
                <p class="artwork-description">{artwork.data.description}</p>
              )}
            </div>
            <div class="card-accent-bottom"></div>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>