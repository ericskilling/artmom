---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const workshops = await getCollection('workshops');
const upcoming = workshops.filter(w => !w.data.past).sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());
const past = workshops.filter(w => w.data.past);

function resolveImagePath(path) {
  if (!path) return path;
  if (typeof path === 'object' && path !== null) {
    path = path.url || path.path || path.src || '';
  }
  if (typeof path !== 'string') return path;
  if (path.startsWith('/assets/')) {
    return '../../' + path;
  }
  return path;
}
---

<BaseLayout title="Workshops - Rachelle Ymay Skilling" description="Comics workshops and classes by Rachelle Ymay Skilling">
  <main>
    <section>
      <h3>Workshops & Classes</h3>
      
      {upcoming.length > 0 && (
        <>
          <h4 class="section-subhead">Upcoming</h4>
          <ul class="exhibition-list">
            {upcoming.map((workshop) => (
              <li class="exhibition-item">
                {workshop.data.image && (
                  <div class="exhibition-image">
                    <img src={resolveImagePath(workshop.data.image)} alt={workshop.data.title} />
                  </div>
                )}
                <h4>{workshop.data.title}</h4>
                <p class="exhibition-venue">
                  {workshop.data.organization && <span class="venue">{workshop.data.organization}</span>}
                  {workshop.data.location && <span class="location">, {workshop.data.location}</span>}
                </p>
                <p class="exhibition-date">
                  {new Date(workshop.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                  {workshop.data.time && ` - ${workshop.data.time}`}
                </p>
                {workshop.data.description && (
                  <p class="exhibition-description">{workshop.data.description}</p>
                )}
                {workshop.data.registerUrl && (
                  <a href={workshop.data.registerUrl} class="btn" target="_blank">Register</a>
                )}
              </li>
            ))}
          </ul>
        </>
      )}
      
      {past.length > 0 && (
        <>
          <h4 class="section-subhead">Past Workshops</h4>
          <ul class="exhibition-list">
            {past.map((workshop) => (
              <li class="exhibition-item">
                {workshop.data.image && (
                  <div class="exhibition-image">
                    <img src={resolveImagePath(workshop.data.image)} alt={workshop.data.title} />
                  </div>
                )}
                <h4>{workshop.data.title}</h4>
                <p class="exhibition-venue">
                  {workshop.data.organization && <span class="venue">{workshop.data.organization}</span>}
                  {workshop.data.location && <span class="location">, {workshop.data.location}</span>}
                </p>
                <p class="exhibition-date">
                  {new Date(workshop.data.date).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
                </p>
                {workshop.data.description && (
                  <p class="exhibition-description">{workshop.data.description}</p>
                )}
              </li>
            ))}
          </ul>
        </>
      )}
    </section>
  </main>
</BaseLayout>