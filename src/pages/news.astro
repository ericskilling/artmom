---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const newsCollection = await getCollection('news');
const newsItems = newsCollection.sort((a, b) => {
  const dateA = new Date(a.data.publish_date || '2024-01-01');
  const dateB = new Date(b.data.publish_date || '2024-01-01');
  return dateB.getTime() - dateA.getTime();
});
---

<BaseLayout 
  title="News - Rachelle Ymay Skilling" 
  description="Essays, publications, and updates from Rachelle Ymay Skilling"
  currentPage="news"
>
  <section class="text-center bg-royal-cobalt relative overflow-visible text-white z-10">

    
    <div class="relative z-10 max-w-[1000px] mx-auto bg-royal-cobalt/70 p-4">
      <h1 class="font-zalando font-bold text-4xl uppercase tracking-wider">News</h1>
    </div>
  </section>

  <div class="section-divider"></div>

  <section class="py-4 px-4">
    {newsItems.length > 0 ? (
      <ul class="list-none p-0">
        {newsItems.map((item) => (
          <li class="py-4 border-b border-white/10 last:border-b-0">
            <h3 class="font-zalando font-bold text-lg uppercase tracking-wider text-white">{item.data.title}</h3>
            {item.data.publish_date && (
              <p class="text-sm text-white/60 mt-0.5">{new Date(item.data.publish_date).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</p>
            )}
            {item.data.description && <p class="text-sm leading-relaxed mt-2 text-white/80">{item.data.description}</p>}
            {item.data.external_link && (
              <a href={item.data.external_link} target="_blank" class="inline-block mt-3 text-sm font-semibold text-electric-magenta underline hover:text-vivid-tangerine">Read More</a>
            )}
          </li>
        ))}
      </ul>
    ) : (
      <p>No news items available yet.</p>
    )}
  </section>
</BaseLayout>