---
import { getCollection } from 'astro:content';

const artworks = await getCollection('artworks');
const sortedArtworks = artworks.sort((a, b) => parseInt(b.data.year) - parseInt(a.data.year));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Portfolio - Rachelle Ymay Skilling</title>
    <meta name="description" content="Portfolio of artworks by Rachelle Ymay Skilling" />
  </head>
  <body>
    <header>
      <nav>
        <h1>Rachelle Ymay Skilling</h1>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/portfolio">Portfolio</a></li>
          <li><a href="/exhibitions">Exhibitions</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <h2>Portfolio</h2>
      <p class="intro">A selection of artworks from 2018 to present.</p>

      <div class="artwork-grid">
        {sortedArtworks.map((artwork) => (
          <article class="artwork-card">
            <h3>{artwork.data.title}</h3>
            <div class="artwork-meta">
              <span class="year">{artwork.data.year}</span>
              <span class="medium">{artwork.data.medium}</span>
            </div>
            {artwork.data.dimensions && (
              <p class="dimensions">{artwork.data.dimensions}</p>
            )}
            {artwork.data.description && (
              <p class="description">{artwork.data.description}</p>
            )}
          </article>
        ))}
      </div>
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} Rachelle Ymay Skilling. All rights reserved.</p>
    </footer>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    line-height: 1.6;
    color: #333;
    background: #fafafa;
  }

  header {
    padding: 2rem;
    background: #fff;
    border-bottom: 1px solid #eee;
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  nav h1 {
    font-size: 1.5rem;
    font-weight: 600;
  }

  nav ul {
    display: flex;
    list-style: none;
    gap: 2rem;
  }

  nav a {
    text-decoration: none;
    color: #333;
    font-weight: 500;
  }

  nav a:hover {
    color: #666;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .intro {
    color: #666;
    margin-bottom: 3rem;
  }

  .artwork-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .artwork-card {
    background: #fff;
    padding: 1.5rem;
    border: 1px solid #eee;
    border-radius: 8px;
  }

  .artwork-card h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .artwork-meta {
    display: flex;
    gap: 1rem;
    color: #666;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .year {
    font-weight: 500;
  }

  .dimensions {
    color: #888;
    font-size: 0.9rem;
    font-style: italic;
    margin-bottom: 1rem;
  }

  .description {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  footer {
    text-align: center;
    padding: 2rem;
    background: #fff;
    border-top: 1px solid #eee;
    color: #666;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    nav {
      flex-direction: column;
      text-align: center;
    }
  }
</style>