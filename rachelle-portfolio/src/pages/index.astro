---
import { getCollection } from 'astro:content';

const artworks = await getCollection('artworks');
const exhibitions = await getCollection('exhibitions');

const about = await getCollection('artist');
const artistInfo = about[0]?.data || {};

const sortedArtworks = artworks.sort((a, b) => parseInt(b.data.year) - parseInt(a.data.year));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{artistInfo.name || 'Rachelle Ymay Skilling'} - Artist</title>
    <meta name="description" content={artistInfo.tagline || "Contemporary Artist from Calgary, Alberta"} />
  </head>
  <body>
    <header>
      <nav>
        <h1>{artistInfo.name || 'Rachelle Ymay Skilling'}</h1>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/portfolio">Portfolio</a></li>
          <li><a href="/exhibitions">Exhibitions</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <section class="hero">
        <h2>{artistInfo.tagline || 'Contemporary Artist'}</h2>
        <p class="bio-preview">{artistInfo.bio?.slice(0, 200)}...</p>
      </section>

      <section class="artworks">
        <h3>Recent Works</h3>
        <div class="artwork-grid">
          {sortedArtworks.slice(0, 4).map((artwork) => (
            <article class="artwork-card">
              <h4>{artwork.data.title}</h4>
              <p class="artwork-year">{artwork.data.year}</p>
              <p class="artwork-medium">{artwork.data.medium}</p>
              {artwork.data.dimensions && (
                <p class="artwork-dimensions">{artwork.data.dimensions}</p>
              )}
              {artwork.data.description && (
                <p class="artwork-description">{artwork.data.description}</p>
              )}
            </article>
          ))}
        </div>
        <a href="/portfolio" class="view-all">View All Works</a>
      </section>

      <section class="exhibitions">
        <h3>Upcoming & Recent Exhibitions</h3>
        <ul class="exhibition-list">
          {exhibitions.slice(0, 3).map((exhibition) => (
            <li class="exhibition-item">
              <h4>{exhibition.data.title}</h4>
              <p>{exhibition.data.venue} - {exhibition.data.location}</p>
              <p class="exhibition-date">
                {new Date(exhibition.data.startDate).toLocaleDateString()} -
                {new Date(exhibition.data.endDate).toLocaleDateString()}
              </p>
            </li>
          ))}
        </ul>
        <a href="/exhibitions" class="view-all">View All Exhibitions</a>
      </section>
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} {artistInfo.name || 'Rachelle Ymay Skilling'}. All rights reserved.</p>
      <p>Based in {artistInfo.location || 'Calgary, Alberta'}</p>
    </footer>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    line-height: 1.6;
    color: #333;
    background: #fafafa;
  }

  header {
    padding: 2rem;
    background: #fff;
    border-bottom: 1px solid #eee;
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  nav h1 {
    font-size: 1.5rem;
    font-weight: 600;
  }

  nav ul {
    display: flex;
    list-style: none;
    gap: 2rem;
  }

  nav a {
    text-decoration: none;
    color: #333;
    font-weight: 500;
  }

  nav a:hover {
    color: #666;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .hero {
    text-align: center;
    padding: 4rem 0;
    border-bottom: 1px solid #eee;
    margin-bottom: 4rem;
  }

  .hero h2 {
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: 1rem;
  }

  .bio-preview {
    max-width: 600px;
    margin: 0 auto;
    color: #666;
  }

  section {
    margin-bottom: 4rem;
  }

  section h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 2rem;
    text-align: center;
  }

  .artwork-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .artwork-card {
    background: #fff;
    padding: 1.5rem;
    border: 1px solid #eee;
    border-radius: 8px;
  }

  .artwork-card h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .artwork-year {
    color: #666;
    font-size: 0.9rem;
  }

  .artwork-medium {
    color: #888;
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }

  .artwork-dimensions {
    color: #888;
    font-size: 0.85rem;
    font-style: italic;
    margin-bottom: 0.5rem;
  }

  .artwork-description {
    font-size: 0.9rem;
    color: #555;
    margin-top: 1rem;
  }

  .exhibition-list {
    list-style: none;
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .exhibition-item {
    padding: 1.5rem;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 8px;
    margin-bottom: 1rem;
  }

  .exhibition-item h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .exhibition-date {
    color: #666;
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  .view-all {
    display: block;
    text-align: center;
    padding: 0.75rem 2rem;
    background: #333;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
    max-width: 200px;
    margin: 0 auto;
  }

  .view-all:hover {
    background: #555;
  }

  footer {
    text-align: center;
    padding: 2rem;
    background: #fff;
    border-top: 1px solid #eee;
    color: #666;
    font-size: 0.9rem;
  }

  footer p {
    margin-bottom: 0.5rem;
  }

  @media (max-width: 768px) {
    nav {
      flex-direction: column;
      text-align: center;
    }

    nav ul {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }

    .hero h2 {
      font-size: 1.5rem;
    }
  }
</style>